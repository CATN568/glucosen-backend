{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": [
    "airbnb-base"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "off",
    "func-names": "off",
    "no-underscore-dangle": "off",
    "consistent-return": "off",
    "max-len": "warn",
    "object-curly-newline": "warn",
    "no-trailing-spaces": "warn",
    "comma-dangle": "warn",
    "radix": "warn",
    "quotes": "warn",
    "import/no-extraneous-dependencies": "off"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".git"
  ]
}
